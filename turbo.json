{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build:ui": {
      "outputs": ["ui/dist/**"]
    },
    "build:ext": {
      "outputs": ["dist/**"]
    },
    "build:mcp": {
      "outputs": ["mcp/dist/**"]
    },
    "build": {
      "dependsOn": ["build:ext", "build:ui", "build:mcp"]
    },
    "package": {
      "dependsOn": ["build:ext", "build:ui", "build:mcp"],
      "outputs": ["*.vsix"]
    }
  }
}
