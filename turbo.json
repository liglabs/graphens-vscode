{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build:ui": {
      "outputs": ["ui/dist/**"]
    },
    "build:ext": {
      "outputs": ["dist/**"]
    },
    "build": {
      "dependsOn": ["build:ext", "build:ui"]
    },
    "package": {
      "dependsOn": ["build:ext", "build:ui"],
      "outputs": ["*.vsix"]
    }
  }
}
