{
  "name": "graphens-ai",
  "displayName": "Graphens AI",
  "description": "AI chat assistant integrated into VS Code sidebar",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "graphens-ai.tutor",
        "isSticky": true,
        "fullName": "Graphens AI Assistant",
        "name": "graphens",
        "description": "Assistant pour des étudiants en informatique."
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "graphens-chat",
          "title": "Graphens AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "graphens-chat": [
        {
          "type": "webview",
          "id": "graphens-ai.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [],
    "menus": {
      "view/title": [
        {
          "command": "graphens-ai.clearChat",
          "when": "view == graphens-ai.chat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Graphens AI"
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build:webview && pnpm run compile:ts",
    "compile": "pnpm run build:webview && pnpm run compile:ts",
    "compile:ts": "tsc -p ./",
    "build:webview": "pnpm --filter graphens-ai-webview build",
    "watch": "tsc -watch -p ./",
    "dev:webview": "pnpm --filter graphens-ai-webview dev",
    "pretest": "pnpm run compile",
    "lint": "eslint src && pnpm --filter graphens-ai-webview lint",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.4.0",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
