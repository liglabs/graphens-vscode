{
  "name": "graphens-vscode",
  "displayName": "Graphens AI",
  "description": "AI chat assistant integrated into VS Code sidebar",
  "version": "0.3.1",
  "packageManager": "pnpm@11.5.2",
  "repository": {
    "url": "https://github.com/LigLabs/graphens-vscode"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "graphens-ai.tutor",
        "isSticky": true,
        "fullName": "Graphens AI Assistant",
        "name": "graphens",
        "description": "Assistant pour des étudiants en informatique.",
        "commands": [
          {
            "name": "debug_readme",
            "description": "Check how getReadme() works"
          },
          {
            "name": "debug_graphens_files",
            "description": "Check how getGraphensFiles() works"
          },
          {
            "name": "debug_open_files",
            "description": "Check how getOpenFiles() works"
          },
          {
            "name": "debug_highlighted_code",
            "description": "Check how getHighlightedCode() works"
          },
          {
            "name": "debug_cheating_guard",
            "description": "Check how isCheating() works"
          },
          {
            "name": "debug_history",
            "description": "Check how getHistory() works"
          },
          {
            "name": "debug_compiler",
            "description": "Check how runCompiler() works"
          },
          {
            "name": "debug_language_server_errors",
            "description": "Check language server diagnostics for the active file"
          }
        ]
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "graphens-chat",
          "title": "Graphens AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "graphens-chat": [
        {
          "type": "webview",
          "id": "graphens-ai.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [],
    "menus": {
      "view/title": [
        {
          "command": "graphens-ai.clearChat",
          "when": "view == graphens-ai.chat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Graphens AI"
    }
  },
  "scripts": {
    "vscode:prepublish": "turbo run build",
    "build:ui": "pnpm --filter graphens-vscode-ui build",
    "build:ext": "vite build --config vite.extension.config.ts",
    "dev:ui": "pnpm --filter graphens-vscode-ui dev",
    "package": "npx vsce package",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.4.0",
    "mocha": "^11.7.5",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "ufo": "^1.6.4",
    "vite": "^8.0.13",
    "zod": "^4.4.3"
  },
  "bundledDependencies": [
    "ufo",
    "zod"
  ]
}
