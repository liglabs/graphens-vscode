{
  "name": "graphens-vscode",
  "displayName": "Graphens AI",
  "description": "AI chat assistant integrated into VS Code sidebar",
  "version": "0.6.1",
  "packageManager": "pnpm@11.5.2",
  "repository": {
    "url": "https://github.com/LigLabs/graphens-vscode"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onLanguage"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "graphens-ai.tutor",
        "isSticky": true,
        "fullName": "Graphens AI Assistant",
        "name": "graphens",
        "description": "Assistant pour des étudiants en informatique.",
        "commands": [
          {
            "name": "debug_readme"
          },
          {
            "name": "debug_graphens_files"
          },
          {
            "name": "debug_open_files"
          },
          {
            "name": "debug_highlighted_code"
          },
          {
            "name": "debug_cheating_guard"
          },
          {
            "name": "debug_history"
          },
          {
            "name": "debug_compiler"
          },
          {
            "name": "debug_language_server_errors"
          },
          {
            "name": "debug_rag"
          },
          {
            "name": "debug_mentioned_files"
          },
          {
            "name": "debug_graphens_config"
          },
          {
            "name": "debug_graphens_sources"
          },
          {
            "name": "debug_session_id"
          },
          {
            "name": "debug_mcp_tools"
          }
        ]
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "graphens-chat",
          "title": "Graphens AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "graphens-chat": [
        {
          "type": "webview",
          "id": "graphens-ai.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [],
    "menus": {
      "view/title": []
    },
    "configuration": {
      "title": "Graphens AI"
    }
  },
  "scripts": {
    "vscode:prepublish": "turbo run build",
    "test": "tsc -p tsconfig.json && node ./dist/test/runTest.js",
    "watch:ui": "pnpm --filter graphens-vscode-ui watch",
    "watch:ext": "vite build --config vite.extension.config.ts --watch",
    "watch": "concurrently \"npm:watch:ext\" \"npm:watch:ui\"",
    "build:ui": "pnpm --filter graphens-vscode-ui build",
    "build:ext": "vite build --config vite.extension.config.ts",
    "dev:ui": "pnpm --filter graphens-vscode-ui dev",
    "package": "npx vsce package",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@graphens/schemas": "github:liglabs/graphens-schemas",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vscode/test-electron": "^2.5.2",
    "concurrently": "^10.0.0",
    "consola": "^3.4.2",
    "eslint": "^10.4.0",
    "mocha": "^11.7.5",
    "ofetch": "^1.5.1",
    "rxjs": "^7.8.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "ufo": "^1.6.4",
    "vite": "^8.0.13",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "bundledDependencies": [
    "consola",
    "ufo",
    "rxjs",
    "yaml",
    "zod",
    "ofetch",
    "@graphens/schemas"
  ]
}
